# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# OpenRouter (chat) - get key at openrouter.ai
OPENROUTER_API_KEY=
# Optional: override the chat model (default: google/gemini-2.0-flash)
# OPENROUTER_MODEL=google/gemini-2.0-flash

# Gemini (embeddings only) - keep this, embeddings use a separate quota
GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Social media sync (scripts/sync-social.ts + GitHub Actions daily cron)
# Twitter/X — get a Bearer Token at developer.twitter.com
TWITTER_BEARER_TOKEN=
TWITTER_PHANEROO_USERNAME=PhanerooMin

# Facebook — Graph API page token (optional; leave blank to skip Facebook)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# Bible API (api.scripture.api.bible) - optional, for verse lookups.
# Leave blank to skip verse lookups; ZOE will still work without them.
BIBLE_API_KEY=
BIBLE_ID_KJV=
BIBLE_ID_NKJV=
BIBLE_ID_AMP=
BIBLE_ID_MSG=
