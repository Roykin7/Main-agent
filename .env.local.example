# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# OpenRouter (chat) - get key at openrouter.ai
OPENROUTER_API_KEY=
# Optional: override the chat model (default: google/gemini-2.0-flash)
# OPENROUTER_MODEL=google/gemini-2.0-flash

# Voyage AI (embeddings) - voyage-3 model, 1024-dim vectors
VOYAGE_API_KEY=

# Gemini - no longer used for embeddings, can be removed
# GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Social media sync (GitHub Actions daily cron)
# Twitter/X — scraped via twscrape (no API key needed).
# TWITTER_BEARER_TOKEN is no longer used.
TWITTER_PHANEROO_USERNAME=Phanerookampala

# Throwaway Twitter account used by twscrape for scraping sessions.
# Create a spare account at twitter.com — do NOT use your main account.
# Run "python scripts/sync-twitter.py --setup" once after setting these.
TWITTER_SCRAPER_USERNAME=
TWITTER_SCRAPER_PASSWORD=
TWITTER_SCRAPER_EMAIL=
TWITTER_SCRAPER_EMAIL_PASSWORD=

# Facebook — Graph API page token (optional; leave blank to skip Facebook)
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=

# API Ninjas (api-ninjas.com) - weather and commodity prices
API_NINJAS_KEY=

# Bible API (api.scripture.api.bible) - optional, for verse lookups.
# Leave blank to skip verse lookups; ZOE will still work without them.
BIBLE_API_KEY=
BIBLE_ID_KJV=
BIBLE_ID_NKJV=
BIBLE_ID_AMP=
BIBLE_ID_MSG=
